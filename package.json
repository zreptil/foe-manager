{
  "name": "foe-manager",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "npm run sync-version && ng build && npm run zip",
    "zip": "npm-build-zip --source=dist/app/browser --destination=dist/app/browser --name=foe-manager_local --name_only=true",
    "i18n-01-extract": "ng extract-i18n app --output-path src/locale --out-file messages.en-GB.xliff --format xliff --progress",
    "i18n-02-upload-english": "start https://crowdin.com/project/foe-manager/content/files",
    "i18n-03-create-messages": "tsc tools/i18n-create-messages.ts && node tools/i18n-create-messages.js && npm run build",
    "i18n-12-extract-and-upload-english": "npm run i18n-01-extract && npm run i18n-02-upload-english",
    "i18n": "npm run i18n-01-extract && npm run i18n-03-create-messages",
    "ng": "ng",
    "start-all": "npm-run-all --parallel backend start",
    "start": "npm run sync-version && ng serve --port 67 --open --ssl --ssl-key server.key --ssl-cert server.crt",
    "test": "ng test",
    "watch": "ng build --watch --configuration development",
    "sync-version": "tsc tools/sync-version.ts && node tools/sync-version.js",
    "postversion": "npm run sync-version",
    "backend": "cmd /k C:\\Users\\msn\\PhpstormProjects\\php8.3.9\\php.exe -S localhost:667 -t C:\\Users\\msn\\WebstormProjects\\foe-manager\\src\\_php\\src",
    "phpliteadmin": "C:\\Users\\msn\\PhpstormProjects\\php8.3.9\\php.exe -S localhost:81 -t C:\\Users\\msn\\WebstormProjects\\foe-manager\\src\\_php"
  },
  "dependencies": {
    "@angular/animations": "^21.2.17",
    "@angular/cdk": "^21.2.7",
    "@angular/common": "^21.2.17",
    "@angular/compiler": "^21.2.17",
    "@angular/core": "^21.2.17",
    "@angular/forms": "^21.2.17",
    "@angular/material": "^21.2.7",
    "@angular/platform-browser": "^21.2.17",
    "@angular/platform-browser-dynamic": "^21.2.17",
    "@angular/router": "^21.2.17",
    "@ng-bootstrap/ng-bootstrap": "^20.0.0",
    "@types/pdfmake": "^0.2.1",
    "@types/ws": "^8.5.4",
    "angular-oauth2-oidc": "^17.0.2",
    "base64-arraybuffer": "^1.0.2",
    "bcryptjs": "^2.4.3",
    "better-npm-audit": "^3.7.3",
    "extract-zip": "^2.0.1",
    "fast-sha256": "^1.3.0",
    "file-saver": "^2.0.5",
    "jszip": "^3.10.1",
    "node-ensure": "^0.0.0",
    "pdfjs-dist": "^4.4.168",
    "pdfmake": "^0.2.7",
    "rxjs": "~7.8.0",
    "sha1": "^1.1.1",
    "tslib": "^2.3.0",
    "utf8-encoding": "^0.1.2",
    "xliff": "^6.1.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.17",
    "@angular/cli": "^21.2.17",
    "@angular/compiler-cli": "^21.2.17",
    "@angular/localize": "^21.2.17",
    "@types/bcryptjs": "^2.4.6",
    "@types/file-saver": "^2.0.5",
    "@types/jasmine": "~4.3.0",
    "@types/node": "^12.11.1",
    "@types/ws": "8.5.4",
    "jasmine-core": "~4.5.0",
    "npm-build-zip": "^1.0.3",
    "npm-run-all": "^4.1.5",
    "typescript": "~5.9.3"
  }
}
